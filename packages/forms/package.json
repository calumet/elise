{
  "name": "@calumet/elise-forms",
  "version": "0.1.2",
  "private": false,
  "description": "Hook useZodForm: integración de react-hook-form + Zod para Elise.",
  "repository": {
    "type": "git",
    "url": "https://github.com/calumet/elise.git",
    "directory": "packages/forms"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --dts",
    "dev": "tsup --watch --dts",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "react-hook-form": "^7.82.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "react": "^19.2.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.4",
    "typescript": "^5.6.3"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "license": "MIT"
}
